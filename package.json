{
    "name": "mini-v-agent",
    "description": "A node-based generative AI workspace",
    "license": "Apache-2.0",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "bin": {
        "mini-v-agent": "agent/index.js"
    },
    "scripts": {
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:compiled": "concurrently \"npm run build:watch\" \"npm run dev:server\"",
        "dev:client": "vite",
        "dev:server": "node --watch --experimental-strip-types server/index.ts",
        "build": "vite build",
        "build:watch": "vite build --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@google/genai": "^1.46.0",
        "axios": "^1.13.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "lucide-react": "^0.577.0",
        "multer": "^2.1.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.5.0",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^11.0.0",
        "@vitejs/plugin-react": "^5.1.0",
        "@vitest/coverage-v8": "^4.1.0",
        "concurrently": "^9.2.1",
        "supertest": "^7.2.2",
        "typescript": "~5.9.3",
        "vite": "7.3.1",
        "vitest": "^4.1.0"
    }
}
